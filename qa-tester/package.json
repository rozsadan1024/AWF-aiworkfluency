{
  "name": "awf-qa",
  "version": "1.0.0",
  "description": "AIWorkFluency QA Testing System",
  "type": "module",
  "bin": {
    "awf-qa": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "qa": "tsx src/index.ts run",
    "qa:quick": "tsx src/index.ts run --profiles junior_marketing --qualities good,bad",
    "qa:full": "tsx src/index.ts run --profiles all --qualities all",
    "cleanup": "tsx src/index.ts cleanup"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.4",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
